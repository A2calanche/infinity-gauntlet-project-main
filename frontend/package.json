  "version": "0.1.0",
  "private": false,
  "description": "Small app that make a todo app and send you a reminder via slack or telegram",
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-fetch-hook": "^1.8.5",
    "react-icons": "^5.6.0",
